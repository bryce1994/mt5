void DrawSRLines()
{
    if(!ShowSRLines) return;
    for(int i = 0; i < g_srCount; i++) {
        string name = g_srLevels[i].objName;
        double lvl  = g_srLevels[i].price;
        color  clr  = g_srLevels[i].isBroken ? ColorBroken :
                      (g_srLevels[i].isResistance ? ColorResistance : ColorSupport);
        int    style = g_srLevels[i].isBroken ? STYLE_DOT : STYLE_SOLID;
        int    width = g_srLevels[i].isBroken ? 1 : 2;

        if(ObjectFind(0, name) < 0)
            ObjectCreate(0, name, OBJ_HLINE, 0, 0, lvl);
        ObjectSetDouble(0, name, OBJPROP_PRICE, lvl);
        ObjectSetInteger(0, name, OBJPROP_COLOR, clr);
        ObjectSetInteger(0, name, OBJPROP_STYLE, style);
        ObjectSetInteger(0, name, OBJPROP_WIDTH, width);
        ObjectSetString(0, name, OBJPROP_TOOLTIP,
            StringFormat("%s %.5f%s",
                g_srLevels[i].isResistance ? "阻力" : "支撑", lvl,
                g_srLevels[i].isBroken ? " [已突破]" : ""));
    }
}

void DrawBRRLabel(int idx, double lvl, bool isLong, string tag)
{
    if(!ShowBRRLabels) return;
    string name = g_brrStates[idx].labelName + "_" + tag;
    if(ObjectFind(0, name) >= 0) ObjectDelete(0, name);
    ObjectCreate(0, name, OBJ_ARROW_LABEL, 0, TimeCurrent(), lvl);
    ObjectSetInteger(0, name, OBJPROP_ARROWCODE, isLong ? 233 : 234);
    ObjectSetInteger(0, name, OBJPROP_COLOR, isLong ? ColorSupport : ColorResistance);
    ObjectSetInteger(0, name, OBJPROP_WIDTH, 2);
    ObjectSetString(0, name, OBJPROP_TOOLTIP,
        StringFormat("BRR%s | %.5f | %s", isLong ? "多" : "空", lvl, tag));
}

void DeleteLabel(int idx)
{
    string base = g_brrStates[idx].labelName;
    ObjectDelete(0, base + "_R");
    ObjectDelete(0, base + "_E");
}

