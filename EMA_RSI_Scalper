//+------------------------------------------------------------------+
//|                                           BRR_MultiTF_EA.mq5    |
//|           BRR形态多周期共振策略 (5M趋势 + 1M入场)                 |
//|   逻辑: 5M识别S/R级别 → 突破确认 → 1M等待回测 → 反转K线入场      |
//+------------------------------------------------------------------+
#property copyright "BRR MultiTF Strategy"
#property version   "2.00"
#property strict

#include <Trade\Trade.mqh>
#include <Trade\PositionInfo.mqh>

//--- 输入参数
input group "=== 多周期设置 ==="
input ENUM_TIMEFRAMES TF_Trend      = PERIOD_M5;   // 趋势/S/R周期
input ENUM_TIMEFRAMES TF_Entry      = PERIOD_M1;   // 入场周期

input group "=== 支撑阻力检测 ==="
input int    SR_Lookback            = 60;           // 回望K线数 (5M)
input int    SR_SwingStrength       = 3;            // 摆动点强度 (左右各N根)
input double SR_MergePips           = 8.0;          // 合并相近级别距离(pips)
input int    SR_MaxLevels           = 12;           // 最大保留级别数

input group "=== BRR形态参数 ==="
input double Break_MinPips          = 5.0;          // 有效突破最小pips (K线收盘)
input double Retest_ZonePips        = 6.0;          // 回测命中区域 ±pips
input int    Retest_MaxBars1M       = 30;           // 回测等待最大1M K线数
input double Reversal_MinBodyPips   = 1.5;          // 反转K线最小实体pips

input group "=== 5M趋势过滤 ==="
input bool   UseEMAFilter           = true;         // 启用EMA趋势过滤
input int    EMA_Fast               = 20;           // 快EMA周期 (5M)
input int    EMA_Slow               = 50;           // 慢EMA周期 (5M)
input bool   UseStructureFilter     = true;         // 启用价格结构过滤 (HH/HL 或 LH/LL)

input group "=== 仓位管理 ==="
input double RiskPercent            = 1.0;          // 单笔风险 (账户%)
input double RR_Ratio               = 2.0;          // 盈亏比 (TP = SL × N)
input double SL_BufferPips          = 3.0;          // 止损缓冲pips (超出S/R外侧)
input int    MaxPositions           = 2;            // 最大同时持仓数

input group "=== 移动止损 ==="
input bool   UseBreakeven           = true;         // 盈亏平衡止损
input double BreakevenTriggerPips   = 15.0;         // 触发盈亏平衡盈利pips
input bool   UseTrailingStop        = false;        // 追踪止损
input double TrailStartPips         = 20.0;         // 追踪止损启动pips
input double TrailDistPips          = 10.0;         // 追踪距离pips

input group "=== 交易时间过滤 ==="
input bool   UseTimeFilter          = false;        // 启用时间过滤
input int    TradingStartHour       = 8;            // 开始交易小时 (服务器时间)
input int    TradingEndHour         = 20;           // 结束交易小时

input group "=== 显示设置 ==="
input bool   ShowSRLines            = true;         // 显示S/R线
input bool   ShowBRRLabels          = true;         // 显示BRR标记
input color  ColorResistance        = clrRed;       // 阻力线颜色
input color  ColorSupport           = clrDodgerBlue;// 支撑线颜色
input color  ColorBroken            = clrGray;      // 已突破线颜色
input int    MagicNumber            = 20260101;     // EA魔术号

//--- 常量
#define MAX_BRR_STATES 20

//--- S/R 级别结构
struct SRLevel {
    double   price;
    bool     isResistance;
    bool     isBroken;       // 已被有效突破
    bool     breakDirection; // true=向上突破, false=向下突破
    datetime breakTime;
    string   objName;
};

//--- BRR 状态跟踪
enum BRR_PHASE {
    BRR_IDLE    = 0,
    BRR_WAITING = 1,   // 等待回测
    BRR_RETESTED= 2    // 已回测，等待反转确认
};

struct BRRState {
    BRR_PHASE phase;
    double    levelPrice;
    bool      isLong;          // true=做多 (突破后做回测买), false=做空
    int       waitBars;        // 已等待K线数
    double    bestRetestPrice; // 回测到的最优价格
    string    labelName;
};

//--- 全局对象
CTrade          g_trade;
CPositionInfo   g_pos;

SRLevel         g_srLevels[MAX_BRR_STATES];
int             g_srCount     = 0;
BRRState        g_brrStates[MAX_BRR_STATES];

int             g_emaFastHdl  = INVALID_HANDLE;
int             g_emaSlowHdl  = INVALID_HANDLE;
double          g_emaFast[];
double          g_emaSlow[];

datetime        g_lastTrendBar = 0;
datetime        g_lastEntryBar = 0;
double          g_point;
double          g_pip;

//+------------------------------------------------------------------+
int OnInit()
{
    g_trade.SetExpertMagicNumber(MagicNumber);
    g_trade.SetDeviationInPoints(20);
    g_trade.SetTypeFilling(ORDER_FILLING_IOC);

    g_point = SymbolInfoDouble(_Symbol, SYMBOL_POINT);
    // 处理5位报价 vs 4位报价
    int digits = (int)SymbolInfoInteger(_Symbol, SYMBOL_DIGITS);
    g_pip = (digits == 3 || digits == 5) ? g_point * 10.0 : g_point;

    g_emaFastHdl = iMA(_Symbol, TF_Trend, EMA_Fast, 0, MODE_EMA, PRICE_CLOSE);
    g_emaSlowHdl = iMA(_Symbol, TF_Trend, EMA_Slow, 0, MODE_EMA, PRICE_CLOSE);

    if(g_emaFastHdl == INVALID_HANDLE || g_emaSlowHdl == INVALID_HANDLE) {
        Alert("BRR EA: EMA指标初始化失败!");
        return INIT_FAILED;
    }

    ArraySetAsSeries(g_emaFast, true);
    ArraySetAsSeries(g_emaSlow, true);

    for(int i = 0; i < MAX_BRR_STATES; i++) {
        g_brrStates[i].phase = BRR_IDLE;
        g_brrStates[i].labelName = "";
    }

    Print("BRR多周期共振EA启动 | 品种:", _Symbol,
          " | 趋势:", EnumToString(TF_Trend),
          " | 入场:", EnumToString(TF_Entry));
    return INIT_SUCCEEDED;
}

//+------------------------------------------------------------------+
void OnDeinit(const int reason)
{
    IndicatorRelease(g_emaFastHdl);
    IndicatorRelease(g_emaSlowHdl);
    ObjectsDeleteAll(0, "BRR_");
}

//+------------------------------------------------------------------+
void OnTick()
{
    // 时间过滤
    if(UseTimeFilter && !IsInTradingHours()) {
        ManageOpenPositions();
        return;
    }

    datetime trendBarTime = iTime(_Symbol, TF_Trend, 0);
    datetime entryBarTime = iTime(_Symbol, TF_Entry, 0);

    bool newTrendBar = (trendBarTime != g_lastTrendBar);
    bool newEntryBar = (entryBarTime != g_lastEntryBar);

    // --- 趋势周期新K线: 更新S/R + 检查突破 ---
    if(newTrendBar) {
        g_lastTrendBar = trendBarTime;
        UpdateSRLevels();
        CheckBreakouts();
        DrawSRLines();
    }

    // --- 入场周期新K线: 检查回测 + 入场信号 ---
    if(newEntryBar) {
        g_lastEntryBar = entryBarTime;
        UpdateBRRWaiting();
        CheckEntrySignals();
    }

    // --- 每Tick: 仓位管理 ---
    ManageOpenPositions();
}

//+------------------------------------------------------------------+
//|                     S/R 级别检测                                   |
//+------------------------------------------------------------------+
void UpdateSRLevels()
{
    // 清除旧对象标签
    if(ShowSRLines) ObjectsDeleteAll(0, "BRR_SR_");

    double highs[], lows[];
    ArraySetAsSeries(highs, true);
    ArraySetAsSeries(lows, true);

    int needed = SR_Lookback + SR_SwingStrength + 2;
    if(CopyHigh(_Symbol, TF_Trend, 1, needed, highs) < needed) return;
    if(CopyLow(_Symbol,  TF_Trend, 1, needed, lows)  < needed) return;

    // 临时数组收集候选级别
    double  candPrices[MAX_BRR_STATES * 2];
    bool    candIsRes[MAX_BRR_STATES * 2];
    int     candCount = 0;
    double  mergeZone = SR_MergePips * g_pip;
    double  closeNow  = iClose(_Symbol, TF_Trend, 1);

    // 检测摆动高点 → 阻力
    for(int i = SR_SwingStrength; i < SR_Lookback && candCount < MAX_BRR_STATES * 2; i++) {
        if(!IsSwingHigh(highs, i)) continue;
        double p = highs[i];
        if(NearAny(p, candPrices, candCount, mergeZone)) continue;
        candPrices[candCount] = p;
        candIsRes[candCount]  = true;
        candCount++;
    }

    // 检测摆动低点 → 支撑
    for(int i = SR_SwingStrength; i < SR_Lookback && candCount < MAX_BRR_STATES * 2; i++) {
        if(!IsSwingLow(lows, i)) continue;
        double p = lows[i];
        if(NearAny(p, candPrices, candCount, mergeZone)) continue;
        candPrices[candCount] = p;
        candIsRes[candCount]  = false;
        candCount++;
    }

    // 保留距当前价最近的N个; 上限不超过 MAX_BRR_STATES
    int keep = MathMin(candCount, MathMin(SR_MaxLevels, MAX_BRR_STATES));
    SortByDistance(candPrices, candIsRes, candCount, closeNow);

    // 保留已突破状态 (合并旧状态)
    SRLevel newLevels[MAX_BRR_STATES];
    int     newCount = 0;
    for(int i = 0; i < keep; i++) {
        newLevels[i].price        = candPrices[i];
        newLevels[i].isResistance = candIsRes[i];
        newLevels[i].isBroken     = false;
        newLevels[i].objName      = "BRR_SR_" + IntegerToString(i);

        // 继承旧突破状态
        for(int j = 0; j < g_srCount; j++) {
            if(MathAbs(g_srLevels[j].price - candPrices[i]) < mergeZone && g_srLevels[j].isBroken) {
                newLevels[i].isBroken       = true;
                newLevels[i].breakDirection = g_srLevels[j].breakDirection;
                newLevels[i].breakTime      = g_srLevels[j].breakTime;
                break;
            }
        }
        newCount++;
    }

    ArrayCopy(g_srLevels, newLevels, 0, 0, newCount);
    g_srCount = newCount;
}

//+------------------------------------------------------------------+
bool IsSwingHigh(double &h[], int idx)
{
    for(int d = 1; d <= SR_SwingStrength; d++)
        if(h[idx] <= h[idx - d] || h[idx] <= h[idx + d]) return false;
    return true;
}
bool IsSwingLow(double &l[], int idx)
{
    for(int d = 1; d <= SR_SwingStrength; d++)
        if(l[idx] >= l[idx - d] || l[idx] >= l[idx + d]) return false;
    return true;
}
bool NearAny(double price, double &arr[], int cnt, double zone)
{
    for(int i = 0; i < cnt; i++)
        if(MathAbs(arr[i] - price) < zone) return true;
    return false;
}

void SortByDistance(double &prices[], bool &isRes[], int total, double ref)
{
    // 简单冒泡排序按距离升序
    for(int i = 0; i < total - 1; i++) {
        for(int j = 0; j < total - i - 1; j++) {
            if(MathAbs(prices[j] - ref) > MathAbs(prices[j + 1] - ref)) {
                double tmp = prices[j]; prices[j] = prices[j+1]; prices[j+1] = tmp;
                bool   tb  = isRes[j];  isRes[j]  = isRes[j+1];  isRes[j+1]  = tb;
            }
        }
    }
}

//+------------------------------------------------------------------+
//|                     突破检测 (5M K线收盘确认)                       |
//+------------------------------------------------------------------+
void CheckBreakouts()
{
    double breakMin = Break_MinPips * g_pip;

    // 使用刚完成的5M K线 (index=1)
    double prevClose = iClose(_Symbol, TF_Trend, 1);

    for(int i = 0; i < g_srCount; i++) {
        if(g_srLevels[i].isBroken) continue;

        double lvl = g_srLevels[i].price;

        // 向上突破阻力
        if(g_srLevels[i].isResistance && prevClose > lvl + breakMin) {
            g_srLevels[i].isBroken       = true;
            g_srLevels[i].breakDirection = true;
            g_srLevels[i].breakTime      = TimeCurrent();
            RegisterBRR(lvl, true);
            PrintFormat("↑ 突破阻力 %.5f | K线收盘 %.5f", lvl, prevClose);
        }
        // 向下突破支撑
        else if(!g_srLevels[i].isResistance && prevClose < lvl - breakMin) {
            g_srLevels[i].isBroken       = true;
            g_srLevels[i].breakDirection = false;
            g_srLevels[i].breakTime      = TimeCurrent();
            RegisterBRR(lvl, false);
            PrintFormat("↓ 突破支撑 %.5f | K线收盘 %.5f", lvl, prevClose);
        }
    }
}

//+------------------------------------------------------------------+
void RegisterBRR(double levelPrice, bool isLong)
{
    // 防止重复注册同一级别
    for(int i = 0; i < MAX_BRR_STATES; i++) {
        if(g_brrStates[i].phase != BRR_IDLE &&
           MathAbs(g_brrStates[i].levelPrice - levelPrice) < SR_MergePips * g_pip) return;
    }
    for(int i = 0; i < MAX_BRR_STATES; i++) {
        if(g_brrStates[i].phase == BRR_IDLE) {
            g_brrStates[i].phase      = BRR_WAITING;
            g_brrStates[i].levelPrice = levelPrice;
            g_brrStates[i].isLong     = isLong;
            g_brrStates[i].waitBars   = 0;
            g_brrStates[i].bestRetestPrice = 0;
            g_brrStates[i].labelName  = "BRR_LBL_" + IntegerToString(i);
            PrintFormat("BRR注册 | 级别:%.5f | 方向:%s", levelPrice, isLong ? "多" : "空");
            return;
        }
    }
    Print("BRR状态槽已满，忽略新突破");
}

//+------------------------------------------------------------------+
//|              1M回测监测 + 趋势过滤                                  |
//+------------------------------------------------------------------+
void UpdateBRRWaiting()
{
    double retestZone = Retest_ZonePips * g_pip;

    // 获取1M已完成K线 (index=1)
    double h1 = iHigh(_Symbol,  TF_Entry, 1);
    double l1 = iLow(_Symbol,   TF_Entry, 1);
    double c1 = iClose(_Symbol, TF_Entry, 1);
    double o1 = iOpen(_Symbol,  TF_Entry, 1);

    // 获取5M EMA
    bool trendBullish = true, trendBearish = true;
    if(UseEMAFilter) {
        if(CopyBuffer(g_emaFastHdl, 0, 0, 2, g_emaFast) < 2) return;
        if(CopyBuffer(g_emaSlowHdl, 0, 0, 2, g_emaSlow) < 2) return;
        trendBullish = (g_emaFast[0] > g_emaSlow[0]);
        trendBearish = (g_emaFast[0] < g_emaSlow[0]);
    }

    for(int i = 0; i < MAX_BRR_STATES; i++) {
        if(g_brrStates[i].phase != BRR_WAITING) continue;

        g_brrStates[i].waitBars++;

        // 超时作废
        if(g_brrStates[i].waitBars > Retest_MaxBars1M) {
            PrintFormat("BRR超时作废 | 级别:%.5f", g_brrStates[i].levelPrice);
            g_brrStates[i].phase = BRR_IDLE;
            DeleteLabel(i);
            continue;
        }
        double lvl    = g_brrStates[i].levelPrice;
        bool   isLong = g_brrStates[i].isLong;

        // 趋势一致性检查
        if(isLong  && UseEMAFilter && !trendBullish) continue;
        if(!isLong && UseEMAFilter && !trendBearish) continue;

        // 回测命中检测
        // 做多回测: 价格回落触碰原阻力(现支撑)附近
        bool retestHit = false;
        if(isLong) {
            retestHit = (l1 >= lvl - retestZone && l1 <= lvl + retestZone) ||
                        (c1 >= lvl - retestZone && c1 <= lvl + retestZone);
        } else {
            retestHit = (h1 >= lvl - retestZone && h1 <= lvl + retestZone) ||
                        (c1 >= lvl - retestZone && c1 <= lvl + retestZone);
        }

        if(retestHit) {
            g_brrStates[i].phase    = BRR_RETESTED;
            g_brrStates[i].waitBars = 0;   // 重置计时器, 用于 RETESTED 超时
            g_brrStates[i].bestRetestPrice = isLong ? l1 : h1;
            PrintFormat("回测命中 | 级别:%.5f | 方向:%s", lvl, isLong ? "多" : "空");
            if(ShowBRRLabels) DrawBRRLabel(i, lvl, isLong, "R");
        }
    }

    // BRR_RETESTED 超时: 同样使用 Retest_MaxBars1M, 防止过期信号长期挂起
    for(int i = 0; i < MAX_BRR_STATES; i++) {
        if(g_brrStates[i].phase != BRR_RETESTED) continue;
        g_brrStates[i].waitBars++;
        if(g_brrStates[i].waitBars > Retest_MaxBars1M) {
            PrintFormat("RETESTED超时作废 | 级别:%.5f", g_brrStates[i].levelPrice);
            g_brrStates[i].phase = BRR_IDLE;
            DeleteLabel(i);
        }
    }
}

//+------------------------------------------------------------------+
//|              1M反转信号确认 + 下单                                   |
//+------------------------------------------------------------------+
void CheckEntrySignals()
{
    if(CountMyPositions() >= MaxPositions) return;

    // 1M已完成K线数据
    double o1 = iOpen(_Symbol,  TF_Entry, 1);
    double h1 = iHigh(_Symbol,  TF_Entry, 1);
    double l1 = iLow(_Symbol,   TF_Entry, 1);
    double c1 = iClose(_Symbol, TF_Entry, 1);
    // 前一根
    double o2 = iOpen(_Symbol,  TF_Entry, 2);
    double h2 = iHigh(_Symbol,  TF_Entry, 2);
    double l2 = iLow(_Symbol,   TF_Entry, 2);
    double c2 = iClose(_Symbol, TF_Entry, 2);

    double ask = SymbolInfoDouble(_Symbol, SYMBOL_ASK);
    double bid = SymbolInfoDouble(_Symbol, SYMBOL_BID);

    for(int i = 0; i < MAX_BRR_STATES; i++) {
        if(g_brrStates[i].phase != BRR_RETESTED) continue;
        if(CountMyPositions() >= MaxPositions) break;

        double lvl    = g_brrStates[i].levelPrice;
        bool   isLong = g_brrStates[i].isLong;

        bool signal = false;
        if(isLong)
            signal = IsBullishSignal(o1, h1, l1, c1, o2, h2, l2, c2, lvl);
        else
            signal = IsBearishSignal(o1, h1, l1, c1, o2, h2, l2, c2, lvl);

        if(!signal) continue;

        // 价格结构过滤 (可选)
        if(UseStructureFilter) {
            if(isLong  && !IsBullishStructure()) continue;
            if(!isLong && !IsBearishStructure()) continue;
        }

        // 计算SL/TP
        double slBuf = SL_BufferPips * g_pip;
        double sl, tp, entry;

        if(isLong) {
            entry = ask;
            sl    = lvl - slBuf;
            double slDist = entry - sl;
            if(slDist <= 0) continue;
            tp = entry + slDist * RR_Ratio;
        } else {
            entry = bid;
            sl    = lvl + slBuf;
            double slDist = sl - entry;
            if(slDist <= 0) continue;
            tp = entry - slDist * RR_Ratio;
        }

        double lots = CalcLots(entry, sl);
        if(lots <= 0) continue;

        bool ok = false;
        if(isLong)
            ok = g_trade.Buy(lots, _Symbol, entry, sl, tp, "BRR多");
        else
            ok = g_trade.Sell(lots, _Symbol, entry, sl, tp, "BRR空");

        if(ok) {
            PrintFormat("✓ BRR%s入场 | 级别:%.5f | 入:%.5f SL:%.5f TP:%.5f | 手:%.2f",
                        isLong ? "多" : "空", lvl, entry, sl, tp, lots);
            if(ShowBRRLabels) DrawBRRLabel(i, lvl, isLong, "E");
            g_brrStates[i].phase = BRR_IDLE;
            DeleteLabel(i);
        } else {
            PrintFormat("× 下单失败 | 错误:%d", GetLastError());
        }
    }
}

//+------------------------------------------------------------------+
//|              反转K线形态识别                                        |
//+------------------------------------------------------------------+

// 看涨反转: 锤子线 / 看涨吞没 / 看涨针形
bool IsBullishSignal(double o1, double h1, double l1, double c1,
                     double o2, double h2, double l2, double c2, double lvl)
{
    double minBody = Reversal_MinBodyPips * g_pip;

    // 1. 锤子线 (Hammer): 下影长 ≥ 实体2倍, 上影 ≤ 实体, 收盘为阳线
    double body1       = MathAbs(c1 - o1);
    double lowerShdw1  = MathMin(o1, c1) - l1;
    double upperShdw1  = h1 - MathMax(o1, c1);
    bool   isHammer    = (c1 > o1) &&                        // 阳线
                         (body1 >= minBody) &&
                         (lowerShdw1 >= 2.0 * body1) &&
                         (upperShdw1 <= 0.5 * body1);

    // 2. 看涨吞没 (Bullish Engulfing)
    bool   isEngulf    = (c2 < o2) &&                        // 前阴线
                         (c1 > o1) &&                        // 当前阳线
                         (o1 <= c2) && (c1 >= o2) &&
                         (c1 - o1 >= minBody);

    // 3. 针形Bar (Pin Bar): 下影 ≥ 整根K线60%, 实体在上1/3
    double range1 = h1 - l1;
    bool   isPinBar = (range1 > 0) &&
                      (lowerShdw1 / range1 >= 0.60) &&
                      (MathMin(o1, c1) >= l1 + range1 * 0.60);

    return (isHammer || isEngulf || isPinBar);
}

// 看跌反转: 射击之星 / 看跌吞没 / 看跌针形
bool IsBearishSignal(double o1, double h1, double l1, double c1,
                     double o2, double h2, double l2, double c2, double lvl)
{
    double minBody = Reversal_MinBodyPips * g_pip;

    // 1. 射击之星 (Shooting Star)
    double body1       = MathAbs(c1 - o1);
    double upperShdw1  = h1 - MathMax(o1, c1);
    double lowerShdw1  = MathMin(o1, c1) - l1;
    bool   isStar      = (c1 < o1) &&
                         (body1 >= minBody) &&
                         (upperShdw1 >= 2.0 * body1) &&
                         (lowerShdw1 <= 0.5 * body1);

    // 2. 看跌吞没 (Bearish Engulfing)
    bool   isEngulf    = (c2 > o2) &&
                         (c1 < o1) &&
                         (o1 >= c2) && (c1 <= o2) &&
                         (o1 - c1 >= minBody);

    // 3. 看跌针形
    double range1 = h1 - l1;
    bool   isPinBar = (range1 > 0) &&
                      (upperShdw1 / range1 >= 0.60) &&
                      (MathMax(o1, c1) <= h1 - range1 * 0.60);

    return (isStar || isEngulf || isPinBar);
}

//+------------------------------------------------------------------+
//|              5M价格结构过滤                                         |
//+------------------------------------------------------------------+
bool IsBullishStructure()
{
    // 近期5M: 高点抬升(HH) + 低点抬升(HL)
    // 用近10根的最高高点 vs 远10根的最高高点
    double highs[], lows[];
    ArraySetAsSeries(highs, true);
    ArraySetAsSeries(lows, true);
    if(CopyHigh(_Symbol, TF_Trend, 1, 20, highs) < 20) return false;
    if(CopyLow(_Symbol,  TF_Trend, 1, 20, lows)  < 20) return false;

    double recentHigh = highs[ArrayMaximum(highs, 0, 10)];
    double oldHigh    = highs[ArrayMaximum(highs, 10, 10)];
    double recentLow  = lows[ArrayMinimum(lows,  0, 10)];
    double oldLow     = lows[ArrayMinimum(lows,  10, 10)];

    return (recentHigh > oldHigh && recentLow > oldLow);
}

bool IsBearishStructure()
{
    double highs[], lows[];
    ArraySetAsSeries(highs, true);
    ArraySetAsSeries(lows, true);
    if(CopyHigh(_Symbol, TF_Trend, 1, 20, highs) < 20) return false;
    if(CopyLow(_Symbol,  TF_Trend, 1, 20, lows)  < 20) return false;

    double recentHigh = highs[ArrayMaximum(highs, 0, 10)];
    double oldHigh    = highs[ArrayMaximum(highs, 10, 10)];
    double recentLow  = lows[ArrayMinimum(lows,  0, 10)];
    double oldLow     = lows[ArrayMinimum(lows,  10, 10)];

    return (recentHigh < oldHigh && recentLow < oldLow);
}

//+------------------------------------------------------------------+
//|              持仓管理: 盈亏平衡 + 追踪止损                          |
//+------------------------------------------------------------------+
void ManageOpenPositions()
{
    for(int i = PositionsTotal() - 1; i >= 0; i--) {
        if(!g_pos.SelectByIndex(i)) continue;
        if(g_pos.Symbol() != _Symbol) continue;
        if(g_pos.Magic() != MagicNumber) continue;

        double open = g_pos.PriceOpen();
        double sl   = g_pos.StopLoss();
        double tp   = g_pos.TakeProfit();
        ulong  tk   = g_pos.Ticket();
        double bid  = SymbolInfoDouble(_Symbol, SYMBOL_BID);
        double ask  = SymbolInfoDouble(_Symbol, SYMBOL_ASK);

        if(g_pos.PositionType() == POSITION_TYPE_BUY) {
            double profit = bid - open;
            double newSL  = sl;

            if(UseBreakeven && profit >= BreakevenTriggerPips * g_pip && sl < open)
                newSL = MathMax(newSL, open + g_pip);

            if(UseTrailingStop && profit >= TrailStartPips * g_pip) {
                double trailSL = bid - TrailDistPips * g_pip;
                if(trailSL > newSL) newSL = trailSL;
            }

            if(newSL > sl + g_point)
                g_trade.PositionModify(tk, newSL, tp);

        } else { // SELL
            double profit = open - ask;
            double newSL  = sl;

            if(UseBreakeven && profit >= BreakevenTriggerPips * g_pip && sl > open)
                newSL = MathMin(newSL, open - g_pip);

            if(UseTrailingStop && profit >= TrailStartPips * g_pip) {
                double trailSL = ask + TrailDistPips * g_pip;
                if(sl == 0 || trailSL < newSL) newSL = trailSL;
            }

            if(sl == 0 || newSL < sl - g_point)
                g_trade.PositionModify(tk, newSL, tp);
        }
    }
}

//+------------------------------------------------------------------+
//|              资金管理                                               |
//+------------------------------------------------------------------+
double CalcLots(double entry, double sl)
{
    double balance   = AccountInfoDouble(ACCOUNT_BALANCE);
    double riskMoney = balance * RiskPercent / 100.0;
    double slDist    = MathAbs(entry - sl);
    if(slDist < g_point) return 0;

    double tickVal  = SymbolInfoDouble(_Symbol, SYMBOL_TRADE_TICK_VALUE);
    double tickSize = SymbolInfoDouble(_Symbol, SYMBOL_TRADE_TICK_SIZE);
    double lots     = riskMoney / (slDist / tickSize * tickVal);

    double minL  = SymbolInfoDouble(_Symbol, SYMBOL_VOLUME_MIN);
    double maxL  = SymbolInfoDouble(_Symbol, SYMBOL_VOLUME_MAX);
    double stepL = SymbolInfoDouble(_Symbol, SYMBOL_VOLUME_STEP);

    lots = MathFloor(lots / stepL) * stepL;
    return MathMax(minL, MathMin(maxL, lots));
}

//+------------------------------------------------------------------+
int CountMyPositions()
{
    int cnt = 0;
    for(int i = PositionsTotal() - 1; i >= 0; i--) {
        if(g_pos.SelectByIndex(i) &&
           g_pos.Symbol() == _Symbol &&
           g_pos.Magic() == MagicNumber) cnt++;
    }
    return cnt;
}

bool IsInTradingHours()
{
    MqlDateTime dt;
    TimeToStruct(TimeCurrent(), dt);
    return (dt.hour >= TradingStartHour && dt.hour < TradingEndHour);
}

