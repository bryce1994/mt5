void DrawDashboard()
{
    string panel = "BRR_PANEL";
    if(ObjectFind(0, panel) < 0)
        ObjectCreate(0, panel, OBJ_LABEL, 0, 0, 0);
    ObjectSetInteger(0, panel, OBJPROP_CORNER, CORNER_LEFT_UPPER);
    ObjectSetInteger(0, panel, OBJPROP_XDISTANCE, 10);
    ObjectSetInteger(0, panel, OBJPROP_YDISTANCE, 20);
    ObjectSetInteger(0, panel, OBJPROP_FONTSIZE, 9);
    ObjectSetInteger(0, panel, OBJPROP_COLOR, clrWhite);

    // 统计活跃BRR状态
    int waiting = 0, retested = 0;
    for(int i = 0; i < MAX_BRR_STATES; i++) {
        if(g_brrStates[i].phase == BRR_WAITING)  waiting++;
        if(g_brrStates[i].phase == BRR_RETESTED) retested++;
    }

    string emaDir = "---";
    if(UseEMAFilter && ArraySize(g_emaFast) > 0 && ArraySize(g_emaSlow) > 0)
        emaDir = (g_emaFast[0] > g_emaSlow[0]) ? "↑ 多头" : "↓ 空头";

    string info = StringFormat(
        "BRR多周期共振 | %s\n"
        "S/R级别: %d  |  突破等待: %d  |  已回测: %d\n"
        "5M趋势(EMA): %s  |  持仓: %d/%d",
        _Symbol, g_srCount, waiting, retested,
        emaDir, CountMyPositions(), MaxPositions);

    ObjectSetString(0, panel, OBJPROP_TEXT, info);
}
